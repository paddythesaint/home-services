rules_version = '2';

// Access is by property membership: a property doc carries a memberEmails
// array, and any signed-in user whose verified email is in that array can
// read and write the property and its subcollections. A legacy clause keeps
// the original owner (whose uid equals the property id) working during the
// one-time transition, before memberEmails has been backfilled.
service cloud.firestore {
  match /databases/{database}/documents {
    function propertyData(pid) {
      return get(/databases/$(database)/documents/properties/$(pid)).data;
    }

    function isMemberOf(data) {
      return request.auth != null
        && request.auth.token.email_verified == true
        && 'memberEmails' in data
        && request.auth.token.email in data.memberEmails;
    }

    // Original single-owner model: the property id is the owner's uid.
    function isLegacyOwner(pid) {
      return request.auth != null && request.auth.uid == pid;
    }

    // Founders: the business/platform plane. Cross-property business data
    // is theirs alone — property members (co-owners like Sally) never see
    // it. Keep this allowlist in sync with src/founders.js.
    function isFounder() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in ['paddythesaint@gmail.com'];
    }

    // The contractor network: one profile per contractor, spanning all
    // properties. Founder-only.
    match /contractors/{contractorId} {
      allow read, write: if isFounder();
    }

    match /properties/{propertyId} {
      // Property creation (founder onboarding flow): any verified signed-in
      // user may create a property that lists themselves as a member. The
      // existing `allow write` can't cover create — it reads resource.data,
      // which doesn't exist yet on a create.
      allow create: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in request.resource.data.memberEmails;
      allow read: if isMemberOf(resource.data) || isLegacyOwner(propertyId);
      // A member (or the legacy owner) may update the property, including its
      // member list. New-member writes only work if you can already write.
      allow write: if isLegacyOwner(propertyId) || isMemberOf(resource.data);

      match /{sub}/{docId} {
        allow read, write: if isLegacyOwner(propertyId)
          || isMemberOf(propertyData(propertyId));
      }
    }
  }
}
